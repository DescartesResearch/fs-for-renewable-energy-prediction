{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}",
        },
        {
            "name": "Python Debugger: CSFS Forward Run",
            "type": "debugpy",
            "request": "launch",
            "program": "src/main.py",
            "console": "integratedTerminal",
            "args": "--run_single_experiment --name debug --hpo_train_time_limit 60 --hpo_max_iter 25 --hpo_early_stop --bootstrapping --n_bootstrap_samples 100 --n_jobs 4 --random_seed 27 --domain wind --asset_id T11 --model mlp --features forecast_available --n_features 6 --hpo_mode per_iteration --fs_method CSFS --fast_mode --direction forward --clustering_method correlation"
        },
        {
            "name": "Python Debugger: CSFS Backward Run",
            "type": "debugpy",
            "request": "launch",
            "program": "src/main.py",
            "console": "integratedTerminal",
            "args": "--run_single_experiment --name debug --hpo_train_time_limit 60 --hpo_max_iter 25 --hpo_early_stop --bootstrapping --n_bootstrap_samples 100 --n_jobs 4 --random_seed 27 --domain wind --asset_id T11 --model mlp --features forecast_available --n_features 6 --hpo_mode per_iteration --fs_method CSFS --fast_mode --direction backward --clustering_method correlation"
        },
        {
            "name": "Python Debugger: Paper exp runner",
            "type": "debugpy",
            "request": "launch",
            "program": "src/run_paper_experiments.py",
            "console": "integratedTerminal",
            "args": "run paper_grid.yaml --output paper_results.pkl --mode parallel",
            "env": {
                "LOGLEVEL": "DEBUG"
            }
        },
        {
            "name": "Python Debugger: Run debug config",
            "type": "debugpy",
            "request": "launch",
            "program": "src/main.py",
            "console": "integratedTerminal",
            "args": "--config-name debug.yaml",
            "env": {
                "LOGLEVEL": "DEBUG"
            }
        }
    ]
}